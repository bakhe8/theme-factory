{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Salla Theme Factory package.json Policy",
  "type": "object",
  "required": ["name", "scripts"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^(theme-)?[a-z][a-z0-9-]{2,63}$"
    },
    "scripts": {
      "type": "object",
      "required": ["production", "development", "watch"],
      "properties": {
        "production": { "type": "string", "minLength": 1 },
        "development": { "type": "string", "minLength": 1 },
        "watch": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "repository": {
      "type": ["object", "string"]
    }
  },
  "additionalProperties": true
}
