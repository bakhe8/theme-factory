{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Salla Theme Factory twilight.json Policy",
  "type": "object",
  "required": [
    "name",
    "identifier",
    "version",
    "repository",
    "author_email",
    "features",
    "settings"
  ],
  "properties": {
    "name": {
      "type": "object",
      "required": ["ar", "en"],
      "properties": {
        "ar": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "author_email": {
      "type": "string",
      "minLength": 3
    },
    "features": {
      "type": "array",
      "items": { "type": "string" }
    },
    "settings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "fields"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "fields": {
            "type": "array",
            "items": { "type": "object" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
