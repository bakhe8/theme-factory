{
  "name": "salla-theme-factory",
  "version": "1.0.0",
  "description": "Professional environment for developing and versioning Salla themes",
  "scripts": {
    "zen:preview": "cd themes/zen-theme && salla theme preview",
    "zen:build": "cd themes/zen-theme && pnpm run production",
    "zen:review": "cd themes/zen-theme && salla theme review",
    "raed:preview": "cd themes/raed && salla theme preview",
    "raed:build": "cd themes/raed && pnpm run production",
    "raed:review": "cd themes/raed && salla theme review",
    "factory:intake": "node factory.js intake",
    "factory:manufacture": "node factory.js manufacture",
    "factory:deliver": "node factory.js deliver",
    "factory:workflow": "node factory.js workflow",
    "factory:display": "node factory.js display",
    "factory:innovation": "node factory.js innovation",
    "factory:fix": "node factory.js fix",
    "factory:create": "node factory.js create",
    "factory:policy": "node factory.js policy",
    "factory:audit": "node factory.js audit",
    "factory:preview": "node factory.js preview",
    "factory:preview:all": "node factory.js preview zen-theme --all-pages --all-fixtures",
    "factory:certify": "node factory.js certify",
    "factory:build": "node factory.js build",
    "factory:component": "node factory.js component",
    "factory:experience": "node factory.js experience",
    "factory:page-experience": "node factory.js page-experience",
    "factory:integration": "node factory.js integration",
    "factory:fixtures": "node factory.js fixtures",
    "factory:vertical": "node factory.js vertical",
    "factory:vertical:theme": "node factory.js vertical theme-gate",
    "factory:coverage": "node factory.js coverage",
    "factory:links": "node factory.js links",
    "factory:browser": "node factory.js browser",
    "factory:rtl": "node factory.js rtl",
    "factory:page-contract": "node factory.js page-contract",
    "factory:git-guard": "node factory.js git-guard",
    "factory:exceptions": "node factory.js exceptions",
    "factory:docs:sync": "node factory.js docs sync",
    "factory:docs:check": "node factory.js docs check",
    "factory:docs:gate": "node factory.js docs gate",
    "factory:docs:status": "node factory.js docs status",
    "factory:apply-specs": "node factory.js apply-specs",
    "factory:style": "node core/apply-style.js",
    "prepare": "husky install",
    "git:tag": "git tag -a v$npm_package_version -m 'New theme version release'"
  },
  "devDependencies": {
    "husky": "^8.0.0"
  },
  "dependencies": {
    "twig": "^3.0.0"
  }
}
